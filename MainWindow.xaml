<Window
    x:Class="UUPDumpWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LexBoosT UUP Dump ISO Downloader v1.3"
    Width="1200"
    Height="900"
    MinWidth="1100"
    MinHeight="800"
    Background="Transparent"
    Icon="Icon.ico"
    WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Border
        x:Name="MainBorder"
        Background="Transparent"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="90" />
                <RowDefinition Height="90" />
                <RowDefinition Height="220" />
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Download Progress Overlay -->
            <Border x:Name="DownloadOverlay"
                    Background="#80000000"
                    Visibility="Collapsed"
                    Grid.RowSpan="7"
                    Panel.ZIndex="100">
                <Border Background="#2D2D2D"
                        CornerRadius="8"
                        Padding="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="400">
                    <StackPanel>
                        <TextBlock x:Name="DownloadTitle"
                                   Text="Downloading necessary files..."
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>
                        <ProgressBar x:Name="DownloadProgress"
                                     Height="25"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Margin="0,0,0,10"/>
                        <TextBlock x:Name="DownloadStatus"
                                   Text="Connecting..."
                                   FontSize="12"
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>

            <!--  Title Bar  -->
            <Border
                Grid.Row="0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock
                        Margin="15,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource DarkTextBrush}"
                        Text="⚡ LexBoosT UUP Dump ISO/Updates Downloader">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="2" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="46"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="MinimizeButton_Click"
                            Content="─"
                            FontSize="16"
                            FontWeight="Light"
                            Foreground="{StaticResource DarkTextBrush}"
                            Style="{StaticResource TitleBarButtonStyle}" />
                        <Button
                            Width="46"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            Content="✕"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="{StaticResource DarkTextBrush}"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Current Windows Version Panel  -->
            <Border
                Grid.Row="1"
                MinHeight="80"
                Margin="30,4,30,6"
                Background="#0078D7"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" />
                </Border.Effect>
                <Grid Margin="10,0,10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Left side: Logo and Windows Version  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Image
                            Width="78"
                            Height="50"
                            Margin="0,0,15,-20"
                            Source="logo.png">
                            <Image.Effect>
                                <DropShadowEffect ShadowDepth="2" />
                            </Image.Effect>
                        </Image>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Current Windows Version:"
                                TextDecorations="Underline" />
                            <TextBlock
                                x:Name="LblCurrentVersionInfo"
                                Margin="0,5,0,-20"
                                FontSize="13"
                                Foreground="White"
                                Text="Loading..."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Right side: Powered by UUP Dump  -->
                    <Border
                        Grid.Column="1"
                        Margin="0,0,10,-20"
                        Padding="15,8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#80005A9E"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBlock VerticalAlignment="Center">
                            <Hyperlink
                                NavigateUri="https://uupdump.net"
                                RequestNavigate="Hyperlink_RequestNavigate"
                                TextDecorations="None">
                                <Span
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White">
                                    ⚡ Powered by <Span FontWeight="Bold" Foreground="#00D4FF">https://uupdump.net</Span>
                                </Span>
                            </Hyperlink>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!--  Search Panel  -->
            <Border
                Grid.Row="2"
                Margin="30,15,30,14"
                Background="#802D2D2D"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <Grid Margin="10,12,10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" MinWidth="66.359" />
                        <ColumnDefinition Width="Auto" MinWidth="96.935" />
                        <ColumnDefinition Width="Auto" MinWidth="92.091" />
                        <ColumnDefinition Width="Auto" MinWidth="105.268" />
                        <ColumnDefinition Width="Auto" MinWidth="68" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Height="21"
                        Margin="0,10,10,0"
                        VerticalAlignment="Top"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource DarkTextBrush}"
                        Text="Search:"
                        TextDecorations="Underline" />

                    <TextBox
                        x:Name="TxtSearch"
                        Grid.ColumnSpan="2"
                        Width="314"
                        Height="42"
                        Margin="61,-3,0,0"
                        Padding="12,10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkPanelBrush}"
                        FontSize="15"
                        Foreground="{StaticResource DarkTextBrush}">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button
                        x:Name="BtnSearch"
                        Grid.Column="2"
                        Margin="11,-3,26,5"
                        Padding="30,14"
                        BorderThickness="0"
                        Click="BtnSearch_Click"
                        Cursor="Hand">
                        <Button.Content>
                            <TextBlock
                                Height="23"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="White"
                                Text="Search" />
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0078D7" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3D3D3D" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <CheckBox
                        x:Name="ChkRetail"
                        Grid.Column="2"
                        Grid.ColumnSpan="2"
                        Height="14"
                        Margin="146,4,10,0"
                        Padding="4,-4,0,0"
                        VerticalAlignment="Center"
                        Checked="RetailFilter_Changed"
                        Content="Retail"
                        FontSize="15"
                        Foreground="{DynamicResource AccentBrush}"
                        IsChecked="True"
                        Unchecked="RetailFilter_Changed" />

                    <CheckBox
                        x:Name="ChkPreview"
                        Grid.Column="4"
                        Height="14"
                        Margin="6,4,20,0"
                        Padding="4,-4,0,0"
                        VerticalAlignment="Center"
                        Checked="RetailFilter_Changed"
                        Content="Preview"
                        FontSize="15"
                        Foreground="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}"
                        Unchecked="RetailFilter_Changed" />

                    <TextBlock
                        Grid.Column="4"
                        Grid.ColumnSpan="2"
                        Height="22"
                        Margin="91,10,5,0"
                        VerticalAlignment="Top"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource DarkTextBrush}"
                        Text="Architecture:"
                        TextDecorations="Underline" />

                    <CheckBox
                        x:Name="ChkAmd64"
                        Grid.Column="6"
                        Width="72"
                        Height="14"
                        Margin="8,3,0,0"
                        Padding="4,-4,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Checked="ArchitectureFilter_Changed"
                        Content="AMD64"
                        FontSize="15"
                        Foreground="{DynamicResource Amd64Brush}"
                        IsChecked="True"
                        Unchecked="ArchitectureFilter_Changed" />

                    <CheckBox
                        x:Name="ChkArm64"
                        Grid.Column="7"
                        Width="68"
                        Height="14"
                        Padding="4,-4,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Checked="ArchitectureFilter_Changed"
                        Content="ARM64"
                        FontSize="15"
                        Foreground="{DynamicResource Arm64Brush}"
                        IsChecked="True"
                        Unchecked="ArchitectureFilter_Changed" Margin="0,4,0,0" />
                </Grid>
            </Border>

            <!--  Builds Panel  -->
            <Border
                Grid.Row="3"
                Margin="30,15"
                Background="#802D2D2D"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="10,0,0,0"
                        Style="{StaticResource SectionHeaderStyle}"
                        Text="Available Builds:"
                        TextDecorations="Underline" />

                    <ListBox
                        x:Name="LstBuilds"
                        Grid.Row="1"
                        Margin="10,0,10,10"
                        SelectionChanged="LstBuilds_SelectionChanged"
                        Style="{StaticResource ListBoxStyle}">
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                    <ScrollViewer x:Name="ScrollViewer" Padding="{TemplateBinding Padding}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        Foreground="{StaticResource DarkTextBrush}"
                                        Text="{Binding Title}" />
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        FontWeight="Bold"
                                        Foreground="White">
                                        <TextBlock.Text>
                                            <Binding Path="BuildNumber" StringFormat="({0})" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock FontWeight="Bold" Foreground="{Binding Architecture, Converter={StaticResource ArchitectureColorConverter}}">
                                        <TextBlock.Text>
                                            <Binding Converter="{StaticResource ArchitectureTextConverter}" Path="Architecture" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock
                        Width="22"
                        Height="23"
                        Margin="888,-67,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="/"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!--  Languages and Editions Panel  -->
            <Grid Grid.Row="4" Margin="30,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Languages  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,2,0"
                    Background="#802D2D2D"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="10,0,0,0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="Languages:"
                            TextDecorations="Underline" />

                        <ListBox
                            x:Name="LstLanguages"
                            Grid.Row="1"
                            Margin="10,0,10,10"
                            SelectionChanged="LstLanguages_SelectionChanged"
                            Style="{StaticResource ListBoxStyle}">
                            <ListBox.Template>
                                <ControlTemplate TargetType="ListBox">
                                    <Border
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                        <ScrollViewer x:Name="ScrollViewer" Padding="{TemplateBinding Padding}">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ListBox.Template>
                        </ListBox>
                    </Grid>
                </Border>

                <!--  GridSplitter  -->

                <!--  Editions  -->
                <Border
                    Grid.Column="2"
                    Margin="2,0,0,0"
                    Background="#802D2D2D"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="10,0,0,0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="Editions:"
                            TextDecorations="Underline" />

                        <ListBox
                            x:Name="LstEditions"
                            Grid.Row="1"
                            Margin="10,0,10,10"
                            SelectionChanged="LstEditions_SelectionChanged"
                            Style="{StaticResource ListBoxStyle}">
                            <ListBox.Template>
                                <ControlTemplate TargetType="ListBox">
                                    <Border
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                        <ScrollViewer x:Name="ScrollViewer" Padding="{TemplateBinding Padding}">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ListBox.Template>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!--  Download Options Panel  -->
            <Border
                Grid.Row="5"
                Margin="30,13,30,4"
                Background="#802D2D2D"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,1">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Download Options Title  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,-20,10"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Options"
                            TextDecorations="Underline" HorizontalAlignment="Center" />

                        <!--  Conversion Options  -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="Conversion Options:"
                                TextDecorations="Underline" />
                            <UniformGrid Columns="4">
                                <CheckBox
                                    x:Name="ChkAutoStart"
                                    Margin="0,0,10,5"
                                    Content="Auto Start"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Start the conversion operation without prompt</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkUpdates"
                                    Margin="0,0,10,5"
                                    Content="Include Updates"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Updates integration is enabled</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkCleanup"
                                    Margin="0,0,10,5"
                                    Content="Cleanup"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Compresses superseded components</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkResetBase"
                                    Margin="0,0,10,5"
                                    Content="ResetBase"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Removes superseded components (requires Cleanup enabled)</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkNetFx3"
                                    Margin="0,0,10,5"
                                    Content=".NET 3.5"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Enables/integrates NETFX3.5</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkSolid"
                                    Margin="0,0,10,5"
                                    Content="ESD Compression"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Compresses install.wim to install.esd with LZMX compression (~30% smaller)</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkSkipEdge"
                                    Margin="0,0,10,5"
                                    Content="Skip Edge"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Skips adding Microsoft Edge</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkSkipISO"
                                    Margin="0,0,10,5"
                                    Content="Skip ISO"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Skips ISO creation, leaves the ISOFolder</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkSkipWinRE"
                                    Margin="0,0,10,5"
                                    Content="Skip WinRE"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Skips adding winre.wim to install.wim</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkLCUwinre"
                                    Margin="0,0,10,5"
                                    Content="LCU WinRE"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Forces LCU integration in winre.wim</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkUpdtBootFiles"
                                    Margin="0,0,10,5"
                                    Content="Update BootFiles"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Bootfiles are updated</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkForceDism"
                                    Margin="0,0,10,5"
                                    Content="Force DISM"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Force the use of DISM</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkRefESD"
                                    Margin="0,0,10,5"
                                    Content="Save Ref ESD"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Saves the ref ESD files the conversion creates and uses</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkSkipLCUmsu"
                                    Margin="0,0,10,5"
                                    Content="Skip LCU MSU"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Skips the creation of the MSU</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkAutoExit"
                                    Margin="0,0,10,5"
                                    Content="Auto Exit"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>When conversion is finished, the script closes without waiting</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkDisableUpdatingUpgrade"
                                    Margin="0,0,10,5"
                                    Content="Disable Updating Upgrade"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Disable updating process optimization by using editions upgrade</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkWim2Swm"
                                    Margin="0,0,10,5"
                                    Content="Split WIM (4GB)"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Splits install.wim into multiple install.swm files (4000MB each)</CheckBox.ToolTip>
                                </CheckBox>
                            </UniformGrid>
                        </StackPanel>

                        <!--  Store Apps Options  -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="Store Apps Options:"
                                TextDecorations="Underline" />
                            <UniformGrid Columns="4">
                                <CheckBox
                                    x:Name="ChkSkipApps"
                                    Margin="0,0,10,5"
                                    Content="Skip Apps"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False"
                                    Checked="ChkSkipApps_Checked"
                                    Unchecked="ChkSkipApps_Unchecked">
                                    <CheckBox.ToolTip>Skips integrating the APPS</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkCustomList"
                                    Margin="0,0,10,5"
                                    Content="Use Custom List"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="True">
                                    <CheckBox.ToolTip>Enable using CustomAppsList.txt to pick and choose the added Apps</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkStubAppsFull"
                                    Margin="0,0,10,5"
                                    Content="Full Stub Apps"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Control preference for Apps which are available as stubs:&#10;0 = Install as stub app (smaller size)&#10;1 = Install as full app (complete features)</CheckBox.ToolTip>
                                </CheckBox>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource DarkTextBrush}"
                                        Text="Apps Level:" />
                                    <ComboBox
                                        x:Name="CmbAppsLevel"
                                        Width="60"
                                        SelectedIndex="0"
                                        ToolTip="Control added Apps for Client editions:&#10;0 = All referenced Apps&#10;1 = Store, Security Health, App Installer, StartExperiencesApp&#10;2 = Level 1 + Photos, Camera, Notepad, Paint&#10;3 = Level 2 + Terminal, Widgets, Mail/Outlook, Clipchamp&#10;4 = Level 3 + Media apps (Music, Video, Codecs, Phone Link)">
                                        <ComboBoxItem Content="0" />
                                        <ComboBoxItem Content="1" />
                                        <ComboBoxItem Content="2" />
                                        <ComboBoxItem Content="3" />
                                    </ComboBox>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>

                        <!--  Virtual Editions Options  -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,10">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="Virtual Editions Options (Enterprise, Education...) (Only if you choose Windows Pro Edition in &quot;Editions&quot; section):"
                                TextDecorations="Underline" />
                            <UniformGrid Columns="4">
                                <CheckBox
                                    x:Name="ChkStartVirtual"
                                    Margin="0,0,10,5"
                                    Content="Create Virtual Editions"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False"
                                    Checked="ChkStartVirtual_Checked"
                                    Unchecked="ChkStartVirtual_Unchecked">
                                    <CheckBox.ToolTip>Enable the creation of virtual editions from the base edition</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVUseDism"
                                    Margin="0,0,10,5"
                                    Content="Use DISM"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Virtual edition creation is done by DISM set-edition</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVAutoStart"
                                    Margin="0,0,10,5"
                                    Content="Auto-Start Creation"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Automatically start the virtual edition creation without confirmation</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVDeleteSource"
                                    Margin="0,0,10,5"
                                    Content="Delete Source"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Deletes the source SKU/Index after virtual editions creation is finished</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVPreserve"
                                    Margin="0,0,10,5"
                                    Content="Preserve Source"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Reserve and keep source distribution folder intact</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVwim2esd"
                                    Margin="0,0,10,5"
                                    Content="Virtual ESD"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Compresses the virtual install.wim to install.esd</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVwim2swm"
                                    Margin="0,0,10,5"
                                    Content="Virtual Split WIM"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Splits virtual install.wim into multiple install.swm files</CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox
                                    x:Name="ChkVSkipISO"
                                    Margin="0,0,10,5"
                                    Content="Virtual Skip ISO"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    IsChecked="False">
                                    <CheckBox.ToolTip>Skips ISO creation for virtual editions</CheckBox.ToolTip>
                                </CheckBox>
                            </UniformGrid>
                        </StackPanel>

                        <!--  Additional Options  -->
                        <StackPanel Grid.Row="4" Margin="0,0,0,10">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="Additional Options:"
                                TextDecorations="Underline" />
                            <UniformGrid Columns="1">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox
                                        x:Name="ChkAddDrivers"
                                        Margin="0,0,10,0"
                                        Content="Add Drivers"
                                        Foreground="{StaticResource DarkTextBrush}"
                                        IsChecked="False"
                                        Checked="ChkAddDrivers_Checked"
                                        Unchecked="ChkAddDrivers_Unchecked">
                                        <CheckBox.ToolTip>Integrates drivers into the image</CheckBox.ToolTip>
                                    </CheckBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox
                                        x:Name="ChkAddAutounattend"
                                        Margin="0,0,10,0"
                                        Content="Add autounattend.xml"
                                        Foreground="{StaticResource DarkTextBrush}"
                                        IsChecked="False">
                                        <CheckBox.ToolTip>Includes autounattend.xml for unattended installation. When enabled, a folder will open for you to add your autounattend.xml file.</CheckBox.ToolTip>
                                    </CheckBox>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource DarkTextBrush}" Text="Create it here: " Margin="0,0,5,0"/>
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,0,0">
                                        <Hyperlink NavigateUri="https://schneegans.de/windows/unattend-generator/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FF26ABE0" TextDecorations="Underline">
                                            https://schneegans.de/windows/unattend-generator/
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>

                        <!--  Buttons Row  -->
                        <Grid Grid.Row="5" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    Text="Save to:"
                                    TextDecorations="Underline" />

                                <TextBox
                                    x:Name="TxtDestination"
                                    Grid.Column="1"
                                    MinWidth="400"
                                    Padding="5"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource DarkBgBrush}"
                                    BorderBrush="{StaticResource DarkPanelBrush}"
                                    Foreground="{StaticResource DarkTextBrush}">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8" />
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Button
                                    x:Name="BtnBrowse"
                                    Grid.Column="2"
                                    Width="40"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="BtnBrowse_Click"
                                    Content="..."
                                    FontWeight="Bold"
                                    Style="{StaticResource ButtonStyle}" />
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    x:Name="BtnDownload"
                                    Grid.Column="0"
                                    MinWidth="120"
                                    MinHeight="35"
                                    Margin="0,0,10,0"
                                    Click="BtnDownload_Click"
                                    Content="Make ISO"
                                    FontWeight="Bold"
                                    Style="{StaticResource SuccessButtonStyle}" />

                                <Button
                                    x:Name="BtnDownloadPack"
                                    Grid.Column="1"
                                    MinWidth="120"
                                    MinHeight="35"
                                    Click="BtnDownloadPack_Click"
                                    Content="Download Update Only"
                                    FontWeight="Bold"
                                    Style="{StaticResource ButtonStyle}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!--  Status Label  -->
            <TextBlock
                x:Name="LblStatus"
                Grid.Row="2"
                Margin="0,0,0,-9"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="#0078D7"
                Text="I await your actions..."
                TextWrapping="Wrap" />

            <!--  Ko-fi Support Link  -->
            <Border
                Grid.Row="6"
                Margin="0,10,0,15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center">
                    <Hyperlink
                        NavigateUri="https://ko-fi.com/lexboostdev"
                        RequestNavigate="Hyperlink_RequestNavigate"
                        TextDecorations="None">
                        <StackPanel Orientation="Horizontal">
                            <Image
                                Width="24"
                                Height="24"
                                Margin="0,0,8,0"
                                Source="logomarkLogo.png" />
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FF26ABE0"
                                Text="Support me on Ko-fi" />
                        </StackPanel>
                    </Hyperlink>
                </TextBlock>
            </Border>
            <TextBlock HorizontalAlignment="Left" Height="28" Margin="30,12,0,0" Grid.Row="6" TextWrapping="Wrap" Text="Version 1.3" VerticalAlignment="Top" Width="94" FontWeight="Bold" FontSize="14" Foreground="White"/>
        </Grid>
    </Border>
</Window>
