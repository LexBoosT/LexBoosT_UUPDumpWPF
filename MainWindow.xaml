<Window x:Class="UUPDumpWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LexBoosT UUP Dump ISO Downloader"
        Height="900" Width="1200"
        MinHeight="800" MinWidth="1100"
        WindowStyle="None"
        Background="Transparent"
        Icon="Icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="MainBorder" Background="Transparent" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="280"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="LexBoosT UUP Dump ISO Downloader"
                          Foreground="{StaticResource DarkTextBrush}"
                          VerticalAlignment="Center" Margin="15,0"
                          FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Width="46" Background="Transparent" Foreground="{StaticResource DarkTextBrush}"
                            BorderThickness="0" Click="MinimizeButton_Click" FontSize="16" FontWeight="Light"
                            Style="{StaticResource TitleBarButtonStyle}"/>
                        <Button Content="✕" Width="46" Background="Transparent" Foreground="{StaticResource DarkTextBrush}"
                            BorderThickness="0" Click="CloseButton_Click" FontSize="14" FontWeight="Bold"
                            Style="{StaticResource TitleBarButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Current Windows Version Panel -->
            <Border Grid.Row="1" Background="#0078D7" Margin="30,30,30,10" MinHeight="80">
                <Grid Margin="10,0,10,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="-16,0,-13,0">
                        <Image Source="logo.png" Width="78" Height="50"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Current Windows Version:"
                                  Foreground="White" FontSize="16" FontWeight="Bold" Width="352"/>
                            <TextBlock x:Name="LblCurrentVersionInfo"
                                  Foreground="White" FontSize="13" Margin="0,5,0,0"
                                  TextWrapping="Wrap"
                                  Text="Loading..." Width="352"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search Panel -->
            <Border Grid.Row="2" Background="{StaticResource DarkPanelBrush}" Margin="30,15">
                <Grid Margin="10,12,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Search:" Foreground="{StaticResource DarkTextBrush}"
                          VerticalAlignment="Top" Margin="0,10,10,0" FontSize="16"/>

                    <TextBox x:Name="TxtSearch"
                        Background="{StaticResource DarkBgBrush}"
                        Foreground="{StaticResource DarkTextBrush}"
                        BorderBrush="{StaticResource DarkPanelBrush}" Padding="12,10" FontSize="15" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center" Width="314" Margin="60,0,0,0"/>

                    <Button Grid.Column="2" x:Name="BtnSearch"
                       BorderThickness="0"
                       Padding="30,14"
                       Margin="10,-10,26,-10" Click="BtnSearch_Click" Cursor="Hand"
                       Height="40">
                        <Button.Content>
                            <TextBlock Text="Search" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25"/>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0078D7"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3D3D3D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <CheckBox Grid.Column="3" x:Name="ChkRetail" Content="Retail"
                         Foreground="{StaticResource DarkTextBrush}"
                         IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>

                    <CheckBox Grid.Column="4" x:Name="ChkPreview" Content="Preview"
                         Foreground="{StaticResource DarkTextBrush}"
                         VerticalAlignment="Center" Margin="0,0,20,0" FontSize="15"/>

                    <TextBlock Grid.Column="5" Text="Arch:" Foreground="{StaticResource DarkTextBrush}"
                          VerticalAlignment="Center" Margin="0,0,5,0" FontSize="16"/>

                    <CheckBox Grid.Column="6" x:Name="ChkAmd64" Content="amd64"
                         Foreground="{StaticResource DarkTextBrush}"
                         IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>

                    <CheckBox Grid.Column="7" x:Name="ChkArm64" Content="arm64"
                         Foreground="{StaticResource DarkTextBrush}"
                         VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>
                </Grid>
            </Border>

            <!-- Builds Panel -->
            <Border Grid.Row="3" Background="{StaticResource DarkPanelBrush}" Margin="30,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Available Builds:" 
                          Style="{StaticResource SectionHeaderStyle}"
                          Margin="10,0,0,0"/>

                    <ListBox Grid.Row="1" x:Name="LstBuilds" 
                        Style="{StaticResource ListBoxStyle}"
                        SelectionChanged="LstBuilds_SelectionChanged"
                        Margin="10,0,10,10"/>
                </Grid>
            </Border>

            <!-- Languages and Editions Panel -->
            <Grid Grid.Row="4" Margin="30,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Languages -->
                <Border Grid.Column="0" Background="{StaticResource DarkPanelBrush}" Margin="0,0,2,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Languages:" 
                              Style="{StaticResource SectionHeaderStyle}"
                              Margin="10,0,0,0"/>

                        <ListBox Grid.Row="1" x:Name="LstLanguages" 
                            Style="{StaticResource ListBoxStyle}"
                            SelectionChanged="LstLanguages_SelectionChanged"
                            Margin="10,0,10,10"/>
                    </Grid>
                </Border>

                <!-- GridSplitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                         Background="{StaticResource DarkPanelBrush}"/>

                <!-- Editions -->
                <Border Grid.Column="2" Background="{StaticResource DarkPanelBrush}" Margin="2,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Editions (select one):" 
                              Style="{StaticResource SectionHeaderStyle}"
                              Margin="10,0,0,0"/>

                        <ListBox Grid.Row="1" x:Name="LstEditions" 
                            Style="{StaticResource ListBoxStyle}"
                            SelectionChanged="LstEditions_SelectionChanged"
                            Margin="10,0,10,10"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Download Options Panel -->
            <Border Grid.Row="5" Background="{StaticResource DarkPanelBrush}" Margin="30,0,30,10">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Download Options:"
                          Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <CheckBox x:Name="ChkUpdates" Content="Include Updates"
                             Foreground="{StaticResource DarkTextBrush}"
                             IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="ChkCleanup" Content="Cleanup"
                             Foreground="{StaticResource DarkTextBrush}"
                             IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="ChkNetFx3" Content=".NET 3.5"
                             Foreground="{StaticResource DarkTextBrush}"
                             IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="ChkSolid" Content="ESD Compression (Solid)"
                             Foreground="{StaticResource DarkTextBrush}"
                             IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="ChkSkipEdge" Content="Skip Edge (Uninstall)"
                             Foreground="{StaticResource DarkTextBrush}"
                             IsChecked="False"/>
                    </WrapPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnDownload" Content="Make ISO"
                           Style="{StaticResource SuccessButtonStyle}"
                           Click="BtnDownload_Click" MinWidth="120" MinHeight="35"
                           Margin="0,0,20,0"/>

                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Save to:"
                                  Foreground="{StaticResource DarkTextBrush}"
                                  VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>

                            <TextBox Grid.Column="1" x:Name="TxtDestination"
                                    Background="{StaticResource DarkBgBrush}"
                                    Foreground="{StaticResource DarkTextBrush}"
                                    BorderBrush="{StaticResource DarkPanelBrush}" Padding="5"
                                    MinWidth="200" VerticalAlignment="Center"/>

                            <Button Grid.Column="2" x:Name="BtnBrowse" Content="..."
                                   Style="{StaticResource ButtonStyle}"
                                   Width="40" Margin="10,0,0,0"
                                   Click="BtnBrowse_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Status Label -->
            <TextBlock Grid.Row="5" x:Name="LblStatus"
                  Foreground="LightGreen" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                  FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                  Margin="0,0,0,10"/>
        </Grid>
    </Border>
</Window>
