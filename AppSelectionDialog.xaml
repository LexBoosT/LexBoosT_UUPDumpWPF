<Window x:Class="UUPDumpWPF.AppSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Applications to Integrate"
        Height="500"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Closing="Window_Closing">

    <Border Background="#2D2D2D" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#0078D7" 
                           Text="Select Applications" TextWrapping="Wrap"/>
                <TextBlock FontSize="12" Foreground="#808080" Margin="0,5,0,0"
                           Text="Choose which Windows Store apps you want to integrate into your installation." TextWrapping="Wrap"/>
                <Border Background="#40FFA500" BorderBrush="#FFFFA500" BorderThickness="1" 
                        CornerRadius="4" Padding="8" Margin="0,10,0,0">
                    <TextBlock FontSize="11" Foreground="#FFFFA500" TextWrapping="Wrap">
                        <Run FontWeight="Bold">⚠ Note:</Run> 
                        <Run Text="Availability of apps depends on your Windows build. Apps that are not available for your build will be automatically skipped without errors."/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Apps List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                <StackPanel x:Name="AppsPanel">
                    <!-- Apps will be populated dynamically -->
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Select All" Width="100" Margin="0,0,10,0"
                        Click="SelectAll_Click" Style="{StaticResource ButtonStyle}"/>
                <Button Content="Select None" Width="100" Margin="0,0,10,0"
                        Click="SelectNone_Click" Style="{StaticResource ButtonStyle}"/>
                <Button Content="Cancel" Width="90" Margin="0,0,10,0"
                        Click="Cancel_Click" Style="{StaticResource ButtonStyle}"/>
                <Button Content="OK" Width="90"
                        Click="OK_Click" Style="{StaticResource SuccessButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
